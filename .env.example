# Primary generator: hosted OpenAI-compatible API.
EVALRAG_GENERATOR=openai_compatible
EVALRAG_LLM_BASE_URL=https://api.openai.com/v1
EVALRAG_LLM_MODEL=gpt-5.4-mini
# Prefer exporting OPENAI_API_KEY in your shell instead of storing it in a file.
# OPENAI_API_KEY=<your key>
EVALRAG_LLM_TEMPERATURE=0.2
EVALRAG_LLM_MAX_TOKENS=1400
EVALRAG_LLM_TOKEN_PARAMETER=max_completion_tokens
EVALRAG_LLM_TIMEOUT_SECONDS=90
EVALRAG_LLM_FALLBACK_ENABLED=true

# Fallback generator: local Ollama-compatible Qwen model.
EVALRAG_FALLBACK_LLM_BASE_URL=http://localhost:11434/v1
EVALRAG_FALLBACK_LLM_MODEL=qwen3:8b
EVALRAG_FALLBACK_LLM_API_KEY=ollama
EVALRAG_FALLBACK_LLM_TEMPERATURE=0.2
EVALRAG_FALLBACK_LLM_MAX_TOKENS=1400
EVALRAG_FALLBACK_LLM_TOKEN_PARAMETER=max_tokens
EVALRAG_FALLBACK_LLM_TIMEOUT_SECONDS=120

# Retrieval and indexing.
EVALRAG_TOP_K=5
EVALRAG_CHUNK_SIZE=420
EVALRAG_CHUNK_OVERLAP=80
EVALRAG_CHUNK_SEMANTIC_ENABLE=true
EVALRAG_CHUNK_SEMANTIC_MODEL=BAAI/bge-small-en-v1.5
EVALRAG_CHUNK_SEMANTIC_DEVICE=cpu
EVALRAG_CHUNK_SEMANTIC_OFFLINE=true
EVALRAG_CHUNK_SEMANTIC_MIN_SIZE=160
EVALRAG_HYBRID_ALPHA=0.35
EVALRAG_LOG_PATH=logs/rag_logs.jsonl
EVALRAG_INDEX_PATH=data/index/chunks.json

# Optional Ragas judge configuration. Ragas eval may call both judge LLMs and embeddings.
EVALRAG_RAGAS_MODEL=gpt-5.4-mini
EVALRAG_RAGAS_EMBEDDING_MODEL=text-embedding-3-small
EVALRAG_RAGAS_MAX_TOKENS=4096
EVALRAG_RAGAS_TEMPERATURE=0.0

# Optional LangSmith tracing. Not required for local JSON logs or Ragas eval.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=<your LangSmith key>
# LANGSMITH_PROJECT=evalrag-agent
